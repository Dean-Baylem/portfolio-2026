---
import Hero from "../components/hero/Hero.astro";
import HeroTitle from "../components/hero/HeroTitle.astro";
import HeroLead from "../components/hero/HeroLead.astro";
import HeroImage from "../components/hero/HeroImage.astro";
import Layout from "../layouts/Layout.astro";
import Divider from "../components/borders/Divider.astro";
import JournalItem from "../components/work/JournalItem.astro";
import { journalEntries } from "../utils/journalContent";
---

<Layout>
    <Hero>
        <HeroTitle
            slot="heading"
            title={"Personal Journal"}
        />
        <HeroLead
            slot="lead"
            lead={"A collection of my personal thoughts, catalogues of experiences, and notes on various topics."}
        />
        <HeroImage
            slot="image"
            src="/hero.webp"
            alt="Hand drawn style hero campfire image"
            width="600"
            height="400"
        />
    </Hero>
    <Divider />
    <section>
        <ul>
            {
                journalEntries.map((entry) => (
                    <JournalItem
                        link={entry.link}
                        title={entry.title}
                        date={entry.date}
                        datetime={entry.datetime}
                    />
                ))
            }
        </ul>
    </section>
</Layout>
