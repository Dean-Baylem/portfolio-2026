---
interface Props {
    link: string;
    title: string;
    date: string;
    datetime: string;
}

const { link, title, date, datetime } = Astro.props;
---

<li class="py-4 flex flex-col gap-1 border-b border-accent">
    <h4>
        <a
            href={link}
            class="font-semibold font-heading text-ink text-lg md:text-xl hover:opacity-80 transition-opacity"
        >
            {title}
        </a>
    </h4>
    <p class="font-body font-light text-ink text-sm md:text-base"><time datetime={datetime}>{date}</time></p>
</li>
