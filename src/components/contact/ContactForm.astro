---
const labelClass = "font-heading font-bold text-ink";
const formRowClass = "flex flex-col gap-1.5";
const inputClass = "bg-secondary py-2 px-3 border border-accent font-handwriting text-ink placeholder:text-[124_119_103_1]";
---

<form
    class="flex flex-col gap-4"
    id="contactForm"
>
    <div class={formRowClass}>
        <label
            for="name"
            class={labelClass}
            >Your Name</label
        >
        <input
            class={inputClass}
            type="text"
            name="name"
            id="name"
            placeholder="Enter your name..."
            required
        />
    </div>
    <div class={formRowClass}>
        <label
            for="email"
            class={labelClass}
            >Email Address</label
        >
        <input
            class={inputClass}
            type="email"
            name="email"
            id="email"
            placeholder="Enter your email..."
            required
        />
    </div>
    <div class={formRowClass}>
        <label
            for="subject"
            class={labelClass}
            >Subject</label
        >
        <input
            class={inputClass}
            type="text"
            name="subject"
            id="subject"
            placeholder="What to discuss?"
            required
        />
    </div>
    <div class={formRowClass}>
        <label
            for="message"
            class={labelClass}
            >Message</label
        >
        <textarea
            class={inputClass}
            name="message"
            id="message"
            rows="8"
            placeholder="Your message..."
            required
        ></textarea>
    </div>
    <div
        class="absolute left-[-5000px] h-1 w-1 overflow-hidden"
        aria-hidden="true"
    >
        <input
            type="text"
            name="location"
            tabindex="-1"
            autocomplete="off"
        />
    </div>
    <div class={formRowClass}>
        <input
            type="submit"
            value="Send Message"
            class="block font-heading font-bold text-sm md:text-base bg-[url('./groovepaper.png')] bg-repeat bg-size-[6.25rem] rounded py-1.5 px-2 border transition-all duration-150 ease-in-out text-white border-shadow bg-highlight hover:text-highlight hover:bg-secondary"
        />
        <span class="font-handwriting text-ink text-sm opacity-80 mt-3">* I typically respond within a few working days.</span>
    </div>
</form>
<script>
    const form = document.getElementById("contactForm") as HTMLFormElement;
    const submitBtn = form?.querySelector("input[type='submit']") as HTMLInputElement;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);

        const honeypot = formData.get("location")?.toString().trim();

        if (honeypot) {
            console.warn("Sorry, there was an error with your submission. Please try again.");
            return;
        }

        formData.append("access_key", import.meta.env.PUBLIC_WEB3FORMS_KEY);

        const originalText = submitBtn?.textContent;

        if (submitBtn) {
            submitBtn.textContent = "Sending...";
            submitBtn.disabled = true;
        }

        try {
            const response = await fetch("https://api.web3forms.com/submit", {
                method: "POST",
                body: formData,
            });

            const data = await response.json();

            if (response.ok) {
                alert("Message sent successfully! Thank you for reaching out.");
                form.reset();
            } else {
                alert("Error: " + data.message);
            }
        } catch (error) {
            alert("Something went wrong. Please try again later.");
        } finally {
            if (submitBtn) {
                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
            }
        }
    });
</script>
