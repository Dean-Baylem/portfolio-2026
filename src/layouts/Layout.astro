---
/* CSS Imports */
import "../styles/global.css";

/* Component Imports */
import Header from "../components/navigation/Header.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width"
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon.svg"
        />
        <link
            rel="icon"
            href="/favicon.ico"
        />
        <meta
            name="generator"
            content={Astro.generator}
        />
        <title>Dean Baylem | Portfolio Journal</title>
        <link
            rel="preconnect"
            href="https://fonts.googleapis.com"
        />
        <link
            rel="preconnect"
            href="https://fonts.gstatic.com"
            crossorigin
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300..700;1,300..700&family=Kalam:wght@300;400;700&family=Playfair:ital,opsz,wght@0,5..1200,300..900;1,5..1200,300..900&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <Header />
        <main class="bg-primary bg-[url(/natural-paper.webp)]">
            <div class="max-[90rem] w-full px-4 md:px-6 lg:px-8 xl:px-14">
                <slot />
            </div>
        </main>
    </body>
</html>
